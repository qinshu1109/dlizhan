{{!< default}}

<style>
  @import url("https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@500;600;700&family=Noto+Sans:wght@500;600;700&family=Noto+Serif+SC:wght@400;500;600&family=Noto+Serif:wght@400;500;600&display=swap");

  :root {
    --bg-main: #FAFAF7;
    --bg-section: #F4F1EC;
    --text-main: #1A1A18;
    --text-muted: #6B6B5F;
    --accent: #8B6F5C;
    --border-soft: #E8E4DE;
    --card-bg: #FFFFFF;
    --placeholder: #DDD7CE;
    --shadow-soft: 0 18px 40px rgba(82, 69, 58, 0.09);
    --container: 1080px;
    --radius: 14px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg-main);
    color: var(--text-main);
    font-family: "Noto Serif SC", "Noto Serif", Georgia, serif;
    font-size: 16px;
    line-height: 1.8;
    text-rendering: optimizeLegibility;
  }

  :lang(en) {
    font-family: "Noto Serif", Georgia, serif;
    font-size: 17px;
    line-height: 1.65;
  }

  h1,
  h2,
  h3,
  h4,
  .button,
  button,
  .meta,
  .post-meta,
  .post-tags,
  .post-navigation,
  .related-posts,
  footer {
    font-family: "Noto Sans SC", "Noto Sans", Arial, sans-serif;
  }

  h1,
  h2,
  h3,
  h4,
  p {
    margin-top: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--accent);
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  .container {
    width: min(calc(100% - 48px), var(--container));
    margin-inline: auto;
  }

  .button,
  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    white-space: nowrap;
  }

  .button:hover,
  button:hover {
    color: #FFFFFF;
    background: #765D4D;
    box-shadow: 0 10px 24px rgba(139, 111, 92, 0.22);
    transform: translateY(-1px);
  }

  .button.secondary {
    border-color: transparent;
    background: transparent;
    color: var(--accent);
    box-shadow: none;
  }

  .button.secondary:hover {
    background: rgba(139, 111, 92, 0.08);
    color: var(--accent);
  }

  .meta {
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .card {
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: var(--card-bg);
    box-shadow: 0 10px 28px rgba(82, 69, 58, 0.06);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .card:hover {
    box-shadow: var(--shadow-soft);
    transform: translateY(-3px);
  }

  .site-main {
    padding: 72px 0 0;
  }

  .post-article {
    width: min(calc(100% - 48px), 900px);
    margin-inline: auto;
  }

  .post-header {
    padding: 18px 0 34px;
    border-bottom: 1px solid var(--border-soft);
  }

  .post-title {
    max-width: 820px;
    margin-bottom: 18px;
    color: var(--text-main);
    font-size: clamp(34px, 5vw, 46px);
    line-height: 1.28;
    letter-spacing: 0;
  }

  .post-excerpt {
    max-width: 720px;
    margin-bottom: 22px;
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1.8;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    align-items: center;
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .post-tag {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    color: var(--accent);
    background: rgba(139, 111, 92, 0.06);
    font-size: 13px;
    font-weight: 600;
  }

  .post-feature-image {
    margin: 34px 0 42px;
    overflow: hidden;
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(139, 111, 92, 0.10), rgba(255, 255, 255, 0.55)),
      var(--placeholder);
    box-shadow: 0 10px 28px rgba(82, 69, 58, 0.06);
  }

  .post-feature-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-reading-tools {
    display: grid;
    gap: 12px;
    margin: 0 0 34px;
  }

  .reading-progress-placeholder,
  .toc-placeholder {
    min-height: 1px;
  }

  .post-content {
    width: min(100%, 760px);
    margin-inline: auto;
    color: var(--text-main);
    font-size: 18px;
    line-height: 1.85;
  }

  .post-content > * + * {
    margin-top: 1.25em;
  }

  .post-content h2,
  .post-content h3,
  .post-content h4 {
    margin-top: 2.2em;
    margin-bottom: 0.72em;
    color: var(--text-main);
    line-height: 1.45;
    letter-spacing: 0;
  }

  .post-content h2 {
    font-size: 24px;
  }

  .post-content h3 {
    font-size: 20px;
  }

  .post-content h4 {
    font-size: 18px;
  }

  .post-content p,
  .post-content li {
    color: var(--text-main);
  }

  .post-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .post-content blockquote {
    margin: 2em 0;
    padding: 18px 22px;
    border-left: 3px solid var(--accent);
    background: var(--bg-section);
    color: var(--text-muted);
  }

  .post-content img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  .post-content figure {
    margin: 2.2em 0;
  }

  .post-content figcaption {
    margin-top: 10px;
    color: var(--text-muted);
    font-family: "Noto Sans SC", "Noto Sans", Arial, sans-serif;
    font-size: 13px;
    line-height: 1.6;
    text-align: center;
  }

  .post-content pre {
    overflow-x: auto;
    padding: 18px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: #F7F4EF;
    font-size: 14px;
    line-height: 1.7;
  }

  .post-content code {
    font-size: 0.92em;
  }

  .post-footer {
    width: min(100%, 760px);
    margin: 56px auto 0;
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
  }

  .post-navigation {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
  }

  .related-posts {
    width: min(calc(100% - 48px), var(--container));
    margin: 76px auto 0;
    padding: 56px 0;
    border-top: 1px solid var(--border-soft);
  }

  .related-posts h2 {
    margin-bottom: 24px;
    font-size: 24px;
    line-height: 1.4;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .related-card {
    padding: 22px;
  }

  .related-card h3 {
    margin-bottom: 10px;
    font-size: 18px;
    line-height: 1.45;
  }

  .related-card p {
    margin-bottom: 12px;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .post-comments {
    width: min(100%, 760px);
    margin: 56px auto 0;
    padding-top: 34px;
    border-top: 1px solid var(--border-soft);
  }

  footer {
    margin-top: 76px;
    border-top: 1px solid var(--border-soft);
    background: #F7F4EF;
    padding: 36px 0;
    text-align: center;
  }

  footer ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px 26px;
    margin: 0 0 14px;
    padding: 0;
    list-style: none;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
  }

  footer p {
    margin-bottom: 0;
    color: var(--text-muted);
    font-size: 13px;
  }

  @media (max-width: 767px) {
    .container,
    .post-article,
    .related-posts {
      width: min(calc(100% - 32px), var(--container));
    }

    .site-main {
      padding-top: 48px;
    }

    .post-title {
      font-size: clamp(30px, 10vw, 38px);
    }

    .post-excerpt,
    .post-content {
      font-size: 16px;
    }

    .post-feature-image {
      margin: 28px 0 34px;
    }

    .post-navigation {
      flex-direction: column;
    }

    .button,
    button {
      width: 100%;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="site-main">
  {{#post}}
    <article class="post-article {{post_class}}">
      <header class="post-header">
        {{#if primary_tag}}
          <div class="post-tags">
            <a class="post-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
          </div>
        {{/if}}

        <h1 class="post-title">{{title}}</h1>

        {{#if custom_excerpt}}
          <p class="post-excerpt">{{custom_excerpt}}</p>
        {{/if}}

        <div class="post-meta">
          <span>{{authors}}</span>
          <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY-MM-DD"}}</time>
          <span>{{reading_time}} min</span>
        </div>
      </header>

      {{#if feature_image}}
        <figure class="post-feature-image">
          <img src="{{feature_image}}" alt="{{title}}">
        </figure>
      {{/if}}

      <div class="post-reading-tools" aria-hidden="true">
        <div class="reading-progress-placeholder"></div>
        <div class="toc-placeholder"></div>
      </div>

      <section class="post-content">
        {{{content}}}
      </section>

      <footer class="post-footer">
        {{#if tags}}
          <div class="post-tags">
            {{#foreach tags}}
              <a class="post-tag" href="{{url}}">{{name}}</a>
            {{/foreach}}
          </div>
        {{/if}}

        <nav class="post-navigation" aria-label="文章导航">
          <a class="button secondary" href="{{@site.url}}">返回首页</a>
          <a class="button" href="{{@site.url}}/#recent">查看最新文章</a>
        </nav>
      </footer>

      <section class="post-comments">
        {{comments}}
      </section>
    </article>

    {{#if primary_tag}}
      <section class="related-posts" aria-label="相关推荐">
        <h2>相关推荐</h2>
        <div class="related-grid">
          <article class="related-card card">
            <h3><a href="{{primary_tag.url}}">{{primary_tag.name}}</a></h3>
            <p>更多同类文章整理在「{{primary_tag.name}}」标签页。</p>
            <a class="button" href="{{primary_tag.url}}">查看更多同类文章</a>
          </article>
        </div>
      </section>
    {{/if}}
  {{/post}}
</main>

<footer>
  <div class="container">
    <ul>
      <li><a href="{{@site.url}}/about/">关于</a></li>
      <li><a href="#" target="_blank" rel="noopener">B站频道</a></li>
      <li><a href="https://cozai.net" target="_blank" rel="noopener">cozai.net</a></li>
      <li><a href="{{@site.url}}/rss/">RSS</a></li>
      <li><a href="mailto:you@example.com">联系</a></li>
    </ul>
    <p>&copy; {{date format="YYYY"}} {{@site.title}}. 保留所有权利。</p>
  </div>
</footer>
