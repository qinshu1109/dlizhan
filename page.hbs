{{!< default}}

<style>
  @import url("https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@500;600;700&family=Noto+Sans:wght@500;600;700&family=Noto+Serif+SC:wght@400;500;600&family=Noto+Serif:wght@400;500;600&display=swap");

  :root {
    --bg-main: #FAFAF7;
    --bg-section: #F4F1EC;
    --text-main: #1A1A18;
    --text-muted: #6B6B5F;
    --accent: #8B6F5C;
    --border-soft: #E8E4DE;
    --card-bg: #FFFFFF;
    --placeholder: #DDD7CE;
    --shadow-soft: 0 18px 40px rgba(82, 69, 58, 0.09);
    --container: 1080px;
    --radius: 14px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg-main);
    color: var(--text-main);
    font-family: "Noto Serif SC", "Noto Serif", Georgia, serif;
    font-size: 16px;
    line-height: 1.8;
    text-rendering: optimizeLegibility;
  }

  h1,
  h2,
  h3,
  .page-meta,
  .button,
  footer {
    font-family: "Noto Sans SC", "Noto Sans", Arial, sans-serif;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--accent);
  }

  img {
    display: block;
    max-width: 100%;
  }

  .container {
    width: min(calc(100% - 48px), var(--container));
    margin-inline: auto;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    white-space: nowrap;
  }

  .button:hover {
    color: #FFFFFF;
    background: #765D4D;
    box-shadow: 0 10px 24px rgba(139, 111, 92, 0.22);
    transform: translateY(-1px);
  }

  .site-main {
    padding-top: 72px;
  }

  .page-article {
    width: min(calc(100% - 48px), 860px);
    margin: 0 auto;
    padding: 72px 0 0;
  }

  .page-header {
    margin-bottom: 38px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border-soft);
    text-align: center;
  }

  .page-title {
    max-width: 780px;
    margin: 0 auto 16px;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.22;
    letter-spacing: 0;
  }

  .page-excerpt {
    max-width: 680px;
    margin: 0 auto;
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1.8;
  }

  .page-feature-image {
    overflow: hidden;
    margin: 0 0 44px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: var(--placeholder);
    box-shadow: var(--shadow-soft);
  }

  .page-feature-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .page-content {
    width: min(100%, 760px);
    margin-inline: auto;
    color: var(--text-main);
    font-size: 18px;
    line-height: 1.85;
  }

  .page-content > * + * {
    margin-top: 1.25em;
  }

  .page-content h2,
  .page-content h3,
  .page-content h4 {
    margin-top: 2.2em;
    margin-bottom: 0.72em;
    color: var(--text-main);
    font-family: "Noto Sans SC", "Noto Sans", Arial, sans-serif;
    line-height: 1.45;
  }

  .page-content h2 {
    font-size: 24px;
  }

  .page-content h3 {
    font-size: 20px;
  }

  .page-content p,
  .page-content li {
    color: var(--text-main);
  }

  .page-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .page-content blockquote {
    margin: 2em 0;
    padding: 18px 22px;
    border-left: 3px solid var(--accent);
    background: var(--bg-section);
    color: var(--text-muted);
  }

  .page-footer {
    width: min(100%, 760px);
    margin: 56px auto 0;
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
  }

  footer {
    margin-top: 76px;
    border-top: 1px solid var(--border-soft);
    background: #F7F4EF;
    padding: 36px 0;
    text-align: center;
  }

  footer ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px 26px;
    margin: 0 0 14px;
    padding: 0;
    list-style: none;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
  }

  footer p {
    margin-bottom: 0;
    color: var(--text-muted);
    font-size: 13px;
  }

  @media (max-width: 767px) {
    .container,
    .page-article {
      width: min(calc(100% - 32px), var(--container));
    }

    .site-main {
      padding-top: 48px;
    }

    .page-article {
      padding-top: 52px;
    }

    .page-title {
      font-size: clamp(30px, 10vw, 38px);
    }

    .page-excerpt,
    .page-content {
      font-size: 16px;
    }

    .button {
      width: 100%;
    }
  }
</style>

<main class="site-main">
  {{#post}}
    <article class="page-article {{post_class}}">
      <header class="page-header">
        <h1 class="page-title">{{title}}</h1>
        {{#if custom_excerpt}}
          <p class="page-excerpt">{{custom_excerpt}}</p>
        {{/if}}
      </header>

      {{#if feature_image}}
        <figure class="page-feature-image">
          <img src="{{feature_image}}" alt="{{title}}">
        </figure>
      {{/if}}

      <section class="page-content">
        {{{content}}}
      </section>

      <footer class="page-footer">
        <a class="button" href="{{@site.url}}">返回首页</a>
      </footer>
    </article>
  {{/post}}
</main>

<footer>
  <div class="container">
    <ul>
      <li><a href="{{@site.url}}/about/">关于</a></li>
      <li><a href="#" target="_blank" rel="noopener">B站频道</a></li>
      <li><a href="https://cozai.net" target="_blank" rel="noopener">cozai.net</a></li>
      <li><a href="{{@site.url}}/rss/">RSS</a></li>
      <li><a href="mailto:you@example.com">联系</a></li>
    </ul>
    <p>&copy; {{date format="YYYY"}} {{@site.title}}. 保留所有权利。</p>
  </div>
</footer>
