<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{meta_title}}</title>
  <meta name="description" content="{{meta_description}}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <style>
    :root {
      --bg-main: #FAFAF7;
      --bg-section: #F4F1EC;
      --text-main: #1A1A18;
      --text-muted: #6B6B5F;
      --accent: #8B6F5C;
      --border-soft: #E8E4DE;
      --card-bg: #FFFFFF;
      --placeholder: #DDD7CE;
      --shadow-soft: 0 18px 40px rgba(82, 69, 58, 0.09);
      --container: 1080px;
      --radius: 14px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background: var(--bg-main);
      color: var(--text-main);
      font-family: "Noto Serif SC", "Noto Serif", Georgia, serif;
      font-size: 16px;
      line-height: 1.8;
      text-rendering: optimizeLegibility;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    a:hover {
      color: var(--accent);
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      border-bottom: 1px solid rgba(232, 228, 222, 0.8);
      background: rgba(250, 250, 247, 0.92);
      backdrop-filter: blur(14px);
    }

    .site-header .container {
      width: min(calc(100% - 48px), var(--container));
      margin-inline: auto;
    }

    .site-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      min-height: 72px;
      font-family: "Noto Sans SC", "Noto Sans", Arial, sans-serif;
    }

    .site-logo {
      color: var(--text-main);
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.04em;
      white-space: nowrap;
    }

    .site-nav ul {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      margin: 0;
      padding: 0;
      list-style: none;
      color: var(--text-muted);
      font-size: 15px;
      font-weight: 600;
    }

    .site-nav-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0 18px;
      border: 1px solid var(--accent);
      border-radius: 999px;
      background: var(--accent);
      color: #FFFFFF;
      font-size: 14px;
      font-weight: 700;
      line-height: 1;
      white-space: nowrap;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .site-nav-cta:hover {
      color: #FFFFFF;
      background: #765D4D;
      box-shadow: 0 10px 24px rgba(139, 111, 92, 0.22);
      transform: translateY(-1px);
    }

    .site-main {
      min-height: 60vh;
    }

    @media (max-width: 767px) {
      .site-header .container {
        width: min(calc(100% - 32px), var(--container));
      }

      .site-nav {
        flex-wrap: wrap;
        gap: 12px 18px;
        padding: 14px 0;
      }

      .site-nav ul {
        order: 3;
        width: 100%;
        justify-content: flex-start;
        gap: 18px;
      }
    }
  </style>
  {{ghost_head}}
</head>
<body class="{{body_class}}">
  <header class="site-header">
    <div class="container">
      <nav class="site-nav" aria-label="主导航">
        <a class="site-logo" href="{{@site.url}}">{{@site.title}}</a>
        <ul>
          <li><a href="{{@site.url}}/#featured">文章</a></li>
          <li><a href="{{@site.url}}/about/">关于</a></li>
          <li><a href="#" target="_blank" rel="noopener">B站</a></li>
        </ul>
        <a class="site-nav-cta" href="{{@site.url}}/#newsletter" data-portal="signup">订阅 Newsletter</a>
      </nav>
    </div>
  </header>

  {{{body}}}

  {{ghost_foot}}
</body>
</html>
